# Stripe keys — REQUIRED
# Testnet (base-sepolia) uses test-mode keys, mainnet (base) uses live-mode keys.
STRIPE_SECRET_KEY_TESTNET=sk_test_...
STRIPE_PUBLISHABLE_KEY_TESTNET=pk_test_...
STRIPE_SECRET_KEY_LIVE=sk_live_...
STRIPE_PUBLISHABLE_KEY_LIVE=pk_live_...

# Optional: bind address and port (Node.js only, ignored on CF Workers)
PORT=8787
HOST=0.0.0.0
